# GNN-Insight Frontend environment variables.
#
# Copy this file to `.env` (or `.env.local`) and adjust for your
# environment. Vite only exposes variables prefixed with `VITE_`.

# REST API base URL used by fetch() calls.
VITE_API_BASE_URL=http://localhost:8000/api

# WebSocket URL used for live training snapshots.
VITE_WS_URL=ws://localhost:8000/ws/train

# GNN-Insight backend environment variables

# Relational metadata
MYSQL_URL=mysql+pymysql://root:root@127.0.0.1:3344/gnn_db

# Mongo replay / metrics
MONGO_URI=mongodb://admin:password@127.0.0.1:27017/

# Redis cache
REDIS_URL=redis://127.0.0.1:6379/0

# Fail fast when MySQL/Mongo/Redis are degraded instead of silently falling back.
# Default is "1" (strict). Set to "0" for local dev without full infrastructure.
REQUIRE_RUNTIME_STACK=1

# Auth
JWT_SECRET=gnn-insight-dev-secret-key-change-in-production
JWT_EXPIRE_MINUTES=1440
DISABLE_AUTH=0

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Blob storage
BLOB_STORE_PROVIDER=minio
LOCAL_BLOB_ROOT=./backend/data/blob_store
S3_ENDPOINT=127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=gnn-insight
S3_SECURE=0

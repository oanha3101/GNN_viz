# GNN-Insight backend environment variables

# ─── Priority Stack (Recommended) ─────────────────────────────────────────────
# Set to 1 to force backend to fail if any service (MySQL, Mongo, Redis) is down.
# If 0, backend will use local SQLite/Files/Memory fallbacks.
REQUIRE_RUNTIME_STACK=1

# MySQL Configuration (Primary Metadata Store)
MYSQL_URL=mysql+pymysql://root:root@127.0.0.1:3344/gnn_db

# MongoDB Configuration (High-volume payload storage)
MONGO_URI=mongodb://admin:password@127.0.0.1:27017/

# Redis Configuration (Embedding cache & Ephemeral data)
REDIS_URL=redis://127.0.0.1:6379/0

# ─── Auth ────────────────────────────────────────────────────────────────────
DISABLE_AUTH=0
JWT_SECRET=gnn-insight-dev-secret-key-change-in-production
JWT_EXPIRE_MINUTES=1440

# ─── Blob Storage ────────────────────────────────────────────────────────────
# Options: local | minio
BLOB_STORE_PROVIDER=minio
LOCAL_BLOB_ROOT=./backend/data/blob_store
S3_ENDPOINT=127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=gnn-insight
S3_SECURE=0
